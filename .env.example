# Copy this file to .env and fill in the values before running the scripts.

# Required: GitHub Personal Access Token with repo/public_repo scope.
GITHUB_TOKEN=ghp_your_token_here

# Optional: GumTree CLI binary path if not available on PATH.
GUMTREE_BIN=/usr/local/bin/gumtree

# OpenAI API credentials for dataset/context generation and remote inference.
OPENAI_API_KEY=sk-your-openai-key
OPENAI_RESPONSES_MODEL=gpt-5.1

# Local LLM endpoint configuration used by detectーcode/3_prompt.py when local=True.
LOCAL_LLM_HOST=127.0.0.1
LOCAL_LLM_PORT=1234
LOCAL_LLM_MODEL=qwen/qwen3-coder-48b
LOCAL_LLM_URL=http://127.0.0.1:1234/v1/chat/completions
